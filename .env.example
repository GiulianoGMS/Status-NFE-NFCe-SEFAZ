API_URL="http://monitor.zorte.com.br/api/status/nfe"
API_URL_NFCE="http://monitor.zorte.com.br/api/status/nfce"

ORACLE_USER="seu_usuario"
ORACLE_PASSWORD="sua_senha"

# Opção 1: Easy Connect (não precisa de mais nada)
ORACLE_CONNECT_STRING="host:1521/service_name"

# Opção 2: alias TNS (ex.: "PROD") definido num tnsnames.ora existente.
# Nesse caso, descomente as duas linhas abaixo:
# ORACLE_CONNECT_STRING="PROD"
# TNS_ADMIN="C:\caminho\para\pasta\com\tnsnames.ora"
